{
  "name": "dental-clinic",
  "version": "1.0.0",
  "description": "Offline Dental Clinic Management System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n \"Vite,API\" -c \"cyan,green\" \"vite\" \"node server/index.js\"",
    "start": "node server/index.js",
    "vite": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "lucide-react": "^0.344.0",
    "mongoose": "^8.2.1",
    "node-sqlite3-wasm": "^0.8.57",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^28.2.10",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.dentalclinic.app",
    "productName": "Dental Clinic",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-sqlite3-wasm/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
